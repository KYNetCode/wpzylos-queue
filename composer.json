{
  "name": "kynetcode/wpzylos-queue",
  "description": "Lightweight background job queue for WPZylos Framework",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "wordpress",
    "wpzylos",
    "queue",
    "jobs",
    "background",
    "async",
    "cron",
    "worker"
  ],
  "homepage": "https://github.com/KYNetCode/wpzylos-queue",
  "authors": [
    {
      "name": "KYNetCode",
      "email": "diggerwp@gmail.com",
      "homepage": "https://github.com/KYNetCode"
    }
  ],
  "support": {
    "issues": "https://github.com/KYNetCode/wpzylos-queue/issues",
    "source": "https://github.com/KYNetCode/wpzylos-queue",
    "docs": "https://wpzylos.com/docs/latest/packages/wpzylos-queue"
  },
  "require": {
      "php": "^8.0",
    "kynetcode/wpzylos-core": "^1.0",
    "kynetcode/wpzylos-database": "^1.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^9.6 || ^10.0",
    "squizlabs/php_codesniffer": "^3.7",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "WPZylos\\Framework\\Queue\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPZylos\\Framework\\Queue\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan analyse --configuration=phpstan.neon",
    "cs": "phpcs --standard=PSR12 src/",
    "cs-fix": "phpcbf --standard=PSR12 src/",
    "qa": [
      "@test",
      "@analyze",
      "@cs"
    ]
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.0.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "funding": [
    {
      "type": "paypal",
      "url": "https://paypal.me/diggerwp"
    }
  ]
}
